{
	"name": "@hina-is/root",
	"private": true,
	"license": "AGPL-3.0",
	"type": "module",
	"workspaces": [
		"packages/*",
		"site"
	],
	"scripts": {
		"check": "bun-workspaces run check",
		"dev": "bun-workspaces run dev @hina-is/site",
		"prebuild": "bun check && bun-workspaces run generate @hina-is/bestdori",
		"build": "bun-workspaces run build @hina-is/site",
		"format": "prettier . --write",
		"format:check": "prettier . --check"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"@xeonlink/prettier-plugin-organize-attributes": "1.1.0",
		"bun-workspaces": "1.5.1",
		"prettier": "3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "0.7.2"
	}
}
