---
import { dayjs } from "~/lib/date";
import NavigationMenu from "./navigation-menu.astro";

const BUILD_DATE = dayjs.tz(__BUILD_DATE__);
---

<header
	class="bg-base-200/67 border-base-content/5 sticky top-0 z-100 border-b backdrop-blur-sm"
	id="header"
>
	<div class="navbar container mx-auto">
		<div class="md:navbar-start">
			<label class="btn btn-ghost btn-square md:hidden" for="drawer-menu">
				<iconify-icon class="size-6" icon="lucide:menu" width="none"
				></iconify-icon>
			</label>

			<button
				class="btn btn-ghost btn-square max-md:hidden"
				popovertarget="header-menu"
				style="anchor-name: --anchor-header-menu"
			>
				<iconify-icon class="size-6" icon="lucide:menu" width="none"
				></iconify-icon>
			</button>
		</div>

		<div
			class="max-md:navbar-start navbar-center"
			style="anchor-name: --anchor-header-site"
		>
			<a class="btn btn-ghost btn-sm text-base font-medium" href="/"
				>hina-is ♥</a
			>

			<button
				class="btn btn-square btn-sm btn-ghost"
				popovertarget="header-site-dropdown"
			>
				<iconify-icon class="size-4" icon="lucide:info" width="none"
				></iconify-icon>
			</button>
		</div>

		<div class="navbar-end">
			<label
				class="swap swap-rotate btn btn-ghost btn-circle"
				title="Toggle theme"
			>
				<input
					class="theme-controller"
					type="checkbox"
					value="coffee"
					aria-label="Toggle dark theme"
				/>

				<iconify-icon class="swap-off size-6" icon="lucide:sun" width="none"
				></iconify-icon>
				<iconify-icon class="swap-on size-6" icon="lucide:moon" width="none"
				></iconify-icon>
			</label>
		</div>
	</div>
</header>

<NavigationMenu
	class="dropdown rounded-box bg-base-200/80 mt-2 w-max shadow-sm max-md:hidden"
	id="header-menu"
	popover
	style="position-anchor: --anchor-header-menu"
/>

<div
	class="dropdown bg-base-200 rounded-box md:dropdown-center mt-1 w-max overflow-visible px-4 py-2 shadow-sm"
	id="header-site-dropdown"
	popover
	style="position-anchor: --anchor-header-site"
>
	Last updated
	<span
		class="tooltip tooltip-bottom underline decoration-dotted"
		data-tip={BUILD_DATE.fromNow()}
	>
		{BUILD_DATE.format("MM/DD/YYYY hh:mm A")}</span
	>
</div>
