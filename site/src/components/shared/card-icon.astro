---
import { IMAGE_FORMAT } from "@hina-is/bestdori/constants";
import type { Bandori } from "@hina-is/bestdori/data";

interface Props {
	card: Bandori.Card;
}

const { card } = Astro.props;

const {
	attribute,
	character: { band, ...character },
} = card;
---

<div
	class="tooltip tooltip-character nth-[-n+3]:tooltip-bottom"
	data-attribute={attribute.slug}
	data-character={character.slug}
>
	<div class="tooltip-content flex max-w-48 flex-col items-center gap-1">
		<div class="max-w-36">
			<span class="line-clamp-2 text-sm">{card.name}</span>
		</div>

		<div class="join!">
			<div class="btn join-item btn-xs btn-accent border border-white">
				<iconify-icon class="size-4" icon="lucide:zap" width="none"
				></iconify-icon>
				{card.skill.multiplier}
			</div>
			<div
				class="btn join-item btn-xs bg-attribute border border-white text-white"
			>
				{card.type} &starf;{card.rarity}
			</div>
		</div>

		<div class="inline-flex items-center justify-center gap-1">
			<img
				class="size-8"
				src={`/assets/attributes/${attribute.slug}.svg`}
				alt=`${attribute.name} icon`
				loading="lazy"
			/>
			<img
				class="size-8"
				src={`/assets/characters/${character.slug}.${IMAGE_FORMAT}`}
				alt={`${character.name} icon`}
				loading="lazy"
			/>
			<img
				class="size-8"
				src={`/assets/bands/${band.slug}.svg`}
				alt={`${band.name} icon`}
				loading="lazy"
			/>
		</div>
	</div>

	<button
		hx-get={`/partials/card/${card.slug}`}
		class="cursor-pointer"
		data-umami-event="view-card"
		data-umami-event-card={card.slug}
		data-umami-event-id={card.id}
	>
		<figure
			class="hover-gallery rounded-box bg-character/25 shadow-band hover:shadow-character htmx-indicator-replace size-20 shadow-md sm:size-24"
		>
			<img
				{...Astro.locals.useThumbhash(`${card.slug}-icon-normal`)}
				src={`/assets/cards/${card.slug}-icon-normal.${IMAGE_FORMAT}`}
				alt={`${card.name} icon`}
				loading="lazy"
			/>
			<img
				{...Astro.locals.useThumbhash(`${card.slug}-icon-trained`)}
				src={`/assets/cards/${card.slug}-icon-trained.${IMAGE_FORMAT}`}
				alt={`${card.name} icon (trained)`}
				loading="lazy"
			/>
		</figure>

		<iconify-icon
			class="htmx-indicator size-20 sm:size-24"
			icon="svg-spinners:90-ring-with-bg"
			width="none"></iconify-icon>
	</button>
</div>
