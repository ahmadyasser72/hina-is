---
import { events } from "@hina-is/bestdori/data";

import BaseLayout from "~/layouts/base-layout.astro";
import { IMAGE_FORMAT } from "~/lib/compressor/constants";
import { pages } from "~/lib/page";

const randomEvent = [...events.values()][
	Math.floor(Math.random() * events.size)
];
---

<BaseLayout
	title={pages.index.title}
	background={{
		...Astro.locals.useThumbhash(`${randomEvent.slug}-background`),
		src: `/assets/events/${randomEvent.slug}-background.${IMAGE_FORMAT}`,
		alt: `${randomEvent.name} background`,
	}}
	description={pages.index.description}
>
	<div class="absolute inset-0 grid place-items-center">
		<div class="flex flex-col items-center">
			<h2 class="badge badge-accent badge-xl w-48 font-medium">hina-is</h2>

			<div class="*:link-hover *:btn *:btn-sm mt-4 grid grid-cols-2 gap-1">
				<a href="/page/events"> Event list </a>
				<a href="/page/stamps"> Stamp list </a>
				<a href="/page/birthday"> Birthday tracker </a>
				<a href="/page/sorter"> Character sorter </a>
			</div>
		</div>
	</div>
</BaseLayout>
