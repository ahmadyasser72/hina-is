---
import { IMAGE_FORMAT } from "@hina-is/bestdori/constants";
import type { Bandori } from "@hina-is/bestdori/data";

interface Props {
	band: Bandori.Band & {
		id: number;
		characters: (Bandori.Character & { id: number })[];
	};
}

const { band } = Astro.props;
---

<div
	class="tooltip group even:tooltip-bottom tooltip-band"
	data-band={band.slug}
>
	<div class="tooltip-content flex flex-col-reverse gap-1 group-even:flex-col">
		<span class="font-medium">{band.name}</span>
		<div class="flex justify-center gap-1">
			{
				band.characters.map(({ name, slug }) => (
					<img
						class="size-8"
						src={`/assets/characters/${slug}.${IMAGE_FORMAT}`}
						alt={`${name} icon`}
						loading="lazy"
					/>
				))
			}
		</div>
	</div>

	<img
		class="size-5"
		src={`/assets/bands/${band.slug}.svg`}
		alt={`${band.name} icon`}
		loading="lazy"
	/>
</div>
