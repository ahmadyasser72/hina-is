---
import { IMAGE_FORMAT } from "@hina-is/bestdori/constants";
import type { Bandori } from "@hina-is/bestdori/data";
import { formatEventType } from "@hina-is/bestdori/utilities";

import IconifyLoader from "~/components/loader/iconify-loader.astro";
import { dayjs } from "~/lib/date";
import EventCardBandIcon from "./_event-card-band-icon.astro";
import EventCardCharacterIcon from "./_event-card-character-icon.astro";
import EventCardProgress from "./_event-card-progress.astro";
import EventCardTime from "./_event-card-time.astro";

interface Props {
	event: Bandori.Event;
	predicted: boolean;
}

const { event, predicted, ...props } = Astro.props;
const { attribute, band, characters, startAt, endAt } = event;

const progress = (() => {
	if (predicted || !startAt.en || !endAt.en) return;

	const now = dayjs();
	const start = dayjs(startAt.en);
	const end = dayjs(endAt.en);

	if (now.isBefore(end)) return { now, start, end };
})();
---

<div class="event-card flex flex-col gap-1" {...props} hx-disinherit="*">
	<div class="card bg-base-100 w-90 flex-1 shadow-sm">
		<figure>
			<img
				class="aspect-3/1 h-32"
				{...Astro.locals.useThumbhash(`${event.slug}-banner`)}
				src={`/assets/events/${event.slug}-banner.${IMAGE_FORMAT}`}
				alt={`${event.name} banner`}
				loading="lazy"
			/>
		</figure>
		<div class="card-body items-center text-center">
			<h2 class="card-title flex-1">
				{event.name}
			</h2>

			<EventCardTime {endAt} region="jp" {startAt} />

			<EventCardTime {endAt} {predicted} region="en" {startAt} />

			<div class="flex flex-wrap justify-center gap-1">
				<div class="badge dark:badge-primary dark:badge-soft font-medium">
					<div
						class="tooltip tooltip-attribute"
						data-attribute={attribute.slug}
						data-tip={attribute.name}
					>
						<img
							class="size-5"
							src={`/assets/attributes/${attribute.slug}.svg`}
							alt=`${attribute.name} icon`
							loading="lazy"
						/>
					</div>

					{formatEventType(event.type)}
				</div>

				{
					Array.isArray(band) ? (
						<div class="badge dark:badge-primary dark:badge-soft">
							{band.map((band) => (
								<EventCardBandIcon {band} />
							))}
						</div>
					) : (
						<div class="badge badge-band font-medium" data-band={band.slug}>
							<img
								class="size-5"
								src={`/assets/bands/${band.slug}.svg`}
								alt={`${band.name} icon`}
								loading="lazy"
							/>

							{band.name}
						</div>
					)
				}
			</div>

			<div class="flex flex-wrap justify-center gap-1">
				{
					characters.length > 5 ? (
						<>
							{characters.slice(0, 4).map((character) => (
								<EventCardCharacterIcon
									{character}
									displayBand={Array.isArray(band)}
								/>
							))}

							<details class="dropdown dropdown-top dropdown-end z-0">
								<summary class="btn btn-circle btn-outline size-10">
									<iconify-icon
										class="size-4"
										icon="lucide:chevron-up"
										width="none"
									/>
								</summary>
								<div class="dropdown-content bg-base-100 rounded-box mb-2 flex w-60 flex-wrap justify-center gap-1 p-2 shadow-sm">
									{characters.slice(4).map((character) => (
										<EventCardCharacterIcon
											{character}
											displayBand={Array.isArray(band)}
										/>
									))}
								</div>
							</details>
						</>
					) : (
						characters.map((character) => (
							<EventCardCharacterIcon
								{character}
								displayBand={Array.isArray(band)}
							/>
						))
					)
				}
			</div>

			{progress && <EventCardProgress {...progress} />}
		</div>
	</div>

	<div class="flex gap-1">
		<a
			class="btn btn-sm btn-info flex-1"
			href={`https://bestdori.com/info/events/${event.id}`}
			rel="noopener noreferrer"
			target="_blank"
		>
			<iconify-icon class="size-4" icon="lucide:external-link" width="none"
			></iconify-icon>
			View on Bestdori!
		</a>

		<button
			hx-get={`/partials/event/${event.slug}`}
			class="btn tooltip tooltip-left btn-sm btn-square btn-soft"
			data-tip="Extra details"
		>
			<IconifyLoader icon="lucide:ellipsis" size-class="size-4" />
		</button>
	</div>
</div>
