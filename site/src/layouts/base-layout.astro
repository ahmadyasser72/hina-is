---
import { Font } from "astro:assets";
import { GOATCOUNTER_ENDPOINT } from "astro:env/server";
import type { JSX } from "astro/jsx-runtime";

import Footer from "~/components/footer.astro";
import Header from "~/components/header.astro";
import NavigationMenu from "~/components/navigation-menu.astro";
import type { PageMetadata } from "~/lib/page";

import "~/styles/global.css";

interface Props {
	background?: JSX.ImgHTMLAttributes;
	metadata: PageMetadata;
}

const { background, metadata } = Astro.props;

const fullTitle = `Hina is ♥ ${metadata.title}`;
const url = new URL(Astro.url.pathname, Astro.url.origin);
const route = metadata.path.replaceAll("/", "_");
const image = new URL(`/open-graph/${route}.webp`, url.origin);
---

<html lang="en">
	<head>
		<script is:inline>
			document.documentElement.dataset.theme = localStorage.theme ?? "";
		</script>

		<meta charset="utf-8" />

		<link href={url} rel="canonical" />

		<link type="image/png" href="/favicon-96x96.png" rel="icon" sizes="96x96" />
		<link type="image/svg+xml" href="/favicon.svg" rel="icon" />
		<link href="/favicon.ico" rel="shortcut icon" />
		<link href="/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
		<meta name="apple-mobile-web-app-title" content="hina-is" />
		<link href="/site.webmanifest" rel="manifest" />

		<Font cssVariable="--font-nunito-sans" preload />

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<title>{fullTitle}</title>
		<meta name="description" content={metadata.description} />

		<meta content="hina-is" property="og:site_name" />
		<meta content="website" property="og:type" />
		<meta content={url} property="og:url" />
		<meta content={fullTitle} property="og:title" />
		<meta content={metadata.description} property="og:description" />
		<meta content={image} property="og:image" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={metadata.description} />
		<meta name="twitter:image" content={image} />

		<meta
			name="google-site-verification"
			content="KpTaI8oT4Be4mwkos6HvICOSM6jjgFnMrlo1iJ649iE"
		/>
	</head>
	<body>
		{
			!Astro.locals.clientTimezone && (
				<div
					hx-get
					hx-trigger="load"
					hx-headers="js:{ 'x-timezone': Intl.DateTimeFormat().resolvedOptions().timeZone }"
					hx-select-oob="#content"
					hx-swap="delete"
				/>
			)
		}

		<div class="drawer">
			<input class="drawer-toggle" id="drawer-menu" type="checkbox" />
			<div class="drawer-content flex h-screen flex-col">
				{
					background && (
						<div class="fixed inset-0 -z-10" id="background-image">
							<img
								class="container mx-auto size-full object-cover brightness-67 select-none dark:brightness-33"
								{...background}
							/>
						</div>
					)
				}

				<div
					class="relative flex flex-1 flex-col scroll-smooth *:container *:mx-auto *:shadow-sm"
					id="container"
				>
					<Header />

					<main class="flex-1 py-8" id="content">
						<slot />
					</main>

					<Footer />
				</div>
			</div>

			<div class="drawer-side z-100 md:hidden">
				<label
					class="drawer-overlay"
					for="drawer-menu"
					aria-label="close sidebar"></label>

				<NavigationMenu class="bg-base-200 min-h-full w-64" />
			</div>
		</div>

		<button
			class="btn btn-sm glass text-shadow-base-300 fixed right-2 z-90 text-shadow-md max-md:bottom-2 md:top-18 md:right-1/2 md:translate-x-1/2"
			id="scroll-to-top"
		>
			Back to top

			<iconify-icon class="size-4" icon="lucide:chevrons-up" width="none"
			></iconify-icon>
		</button>

		{
			GOATCOUNTER_ENDPOINT && (
				<script
					data-goatcounter={GOATCOUNTER_ENDPOINT}
					src="/goatcounter.js"
					async
					is:inline
				/>
			)
		}
	</body>
</html>

<script>
	import "iconify-icon";
	import "~/lib/global";
	import "~/lib/htmx";

	// scroll to url fragment on page load
	window.addEventListener("load", () => {
		const hash = window.location.hash;
		if (!hash) return;

		document.querySelector(hash)?.scrollIntoView();
	});
</script>
