{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"paths": {
			"~/*": ["./src/*"],
			"react": ["node_modules/preact/compat"],
			"react-dom": ["node_modules/preact/compat"]
		}
	}
}
